#!/usr/bin/env bash
set -euo pipefail

# Resolve repo root from this script's location so the wrapper follows the
# checkout instead of a hardcoded path. Honor $REPO override for tests that
# need to redirect to a scratch copy. This file lives in scripts/, so the
# repo root is one level up.
REPO="${REPO:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
if [ ! -d "$REPO/src/eduflow" ] || [ ! -d "$REPO/scripts" ]; then
  echo "[eduflowteam] ERROR: resolved REPO=$REPO does not look like EduFlow-Team-orch (missing src/eduflow or scripts/)" >&2
  exit 1
fi
. "$REPO/scripts/eduflow-team-env.sh"
exec python3 -c 'from eduflow import cli; raise SystemExit(cli.main())' "$@"
