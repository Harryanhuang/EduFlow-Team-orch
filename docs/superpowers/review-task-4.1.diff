diff --git a/tests/unit/test_runtime_paths_permissions.py b/tests/unit/test_runtime_paths_permissions.py
new file mode 100644
index 00000000..a7030b17
--- /dev/null
+++ b/tests/unit/test_runtime_paths_permissions.py
@@ -0,0 +1,23 @@
+import os
+import stat
+from pathlib import Path
+
+
+def test_state_dir_is_created_with_700(tmp_path, monkeypatch):
+    monkeypatch.setenv("EDUFLOW_STATE_DIR", str(tmp_path / "state"))
+    from eduflow.runtime import paths
+
+    p = paths.state_dir()
+    assert p.exists()
+    mode = stat.S_IMODE(p.stat().st_mode)
+    assert mode == 0o700
+
+
+def test_facts_dir_is_created_with_700(tmp_path, monkeypatch):
+    monkeypatch.setenv("EDUFLOW_STATE_DIR", str(tmp_path / "state"))
+    from eduflow.runtime import paths
+
+    p = paths.facts_dir()
+    assert p.exists()
+    mode = stat.S_IMODE(p.stat().st_mode)
+    assert mode == 0o700
